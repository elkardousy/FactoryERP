# FactoryERP — Environment Variables
# Copy this file to .env and fill in real values before running the application.
# NEVER commit .env to version control.
# All Prisma CLI commands require DATABASE_URL prefixed explicitly (prisma.config.ts skips .env loading).

# ─── Application ──────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3000
APP_NAME=Factory ERP

# ─── Database ─────────────────────────────────────────────────────────────────

# PostgreSQL container credentials (used by docker-compose.dev.yml)
POSTGRES_USER=factory_dev
POSTGRES_PASSWORD=change_me_locally
POSTGRES_DB=factory_erp

# Full connection URL (used by application and all Prisma CLI commands)
DATABASE_URL=postgresql://factory_dev:change_me_locally@localhost:5432/factory_erp

# ─── JWT ──────────────────────────────────────────────────────────────────────

# MANDATORY: Replace with a random string of at least 32 characters.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=minimum_32_char_secret_change_me_in_production

JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=7d

# ─── Logging ──────────────────────────────────────────────────────────────────

# Valid values: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# ─── PgAdmin (optional — docker compose --profile tools) ──────────────────────

PGADMIN_EMAIL=admin@factory.local
PGADMIN_PASSWORD=change_me_locally
