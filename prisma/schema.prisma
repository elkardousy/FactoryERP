generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["factory"]
}

enum WarehouseTypeEnum {
  RAW
  WIP
  FINISHED_GOODS
  @@map("warehouse_type_enum")
  @@schema("factory")
}

enum ContainerStatusEnum {
  DRAFT
  IN_AUDIT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  POSTED
  @@map("container_status_enum")
  @@schema("factory")
}

enum DiscrepancyTypeEnum {
  SHORTAGE
  OVERAGE
  DAMAGE
  UNEXPECTED
  @@map("discrepancy_type_enum")
  @@schema("factory")
}

enum ReleaseTypeEnum {
  FULL
  PARTIAL
  @@map("release_type_enum")
  @@schema("factory")
}

enum OrderStatusEnum {
  DRAFT
  PLANNED
  IN_PRODUCTION
  PRODUCTION_COMPLETE
  CLOSED
  @@map("order_status_enum")
  @@schema("factory")
}

enum PartStatusEnum {
  PENDING
  RELEASED
  COMPLETE
  RETURNED
  @@map("part_status_enum")
  @@schema("factory")
}

enum StageStatusEnum {
  PENDING
  IN_PROGRESS
  COMPLETE
  @@map("stage_status_enum")
  @@schema("factory")
}

enum ScrapTypeEnum {
  SEWING_DEFECT
  MATERIAL_DEFECT
  STAIN
  DAMAGE
  SIZE_ISSUE
  OTHER
  @@map("scrap_type_enum")
  @@schema("factory")
}

enum IncompleteReasonEnum {
  MISSING_PART
  MISSING_MATERIAL
  PRODUCTION_ISSUE
  OTHER
  @@map("incomplete_reason_enum")
  @@schema("factory")
}

enum TxnTypeEnum {
  RECEIVING
  RELEASE
  WIP_CONSUMPTION
  QUALITY_OUTPUT
  PACKING
  RETURN
  ADJUSTMENT
  SUPPLEMENTARY_RELEASE
  @@map("txn_type_enum")
  @@schema("factory")
}

enum BagStatusEnum {
  RECEIVED
  AVAILABLE
  RESERVED
  RELEASED
  IN_WIP
  RETURNED
  CLOSED
  @@map("bag_status_enum")
  @@schema("factory")
}

enum PackingOrderStatusEnum {
  DRAFT
  IN_PROCESS
  ASSEMBLED
  VERIFIED
  POSTED
  CANCELLED
  @@map("packing_order_status_enum")
  @@schema("factory")
}

enum EmployeeTypeEnum {
  WORKER
  SUPERVISOR
  MANAGER
  @@map("employee_type_enum")
  @@schema("factory")
}

enum ShiftTypeEnum {
  MORNING
  AFTERNOON
  NIGHT
  @@map("shift_type_enum")
  @@schema("factory")
}

enum AttendanceStatusEnum {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
  PUBLIC_HOLIDAY
  @@map("attendance_status_enum")
  @@schema("factory")
}

enum MachineTypeEnum {
  OVERLOCK
  SINGER
  ZIGZAG
  TWO_NEEDLE
  FORMATTER
  TICKET
  OTHER
  @@map("machine_type_enum")
  @@schema("factory")
}

enum MachineStatusEnum {
  INACTIVE
  ACTIVE
  BREAKDOWN
  MAINTENANCE
  STOPPED
  @@map("machine_status_enum")
  @@schema("factory")
}

enum DowntimeReasonEnum {
  BREAKDOWN
  PREVENTIVE_MAINTENANCE
  CORRECTIVE_MAINTENANCE
  OPERATOR_STOP
  POWER_FAILURE
  MATERIAL_WAITING
  CHANGEOVER
  QUALITY_ISSUE
  OTHER
  @@map("downtime_reason_enum")
  @@schema("factory")
}

enum WorkflowStatusEnum {
  DRAFT
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  ESCALATED
  CANCELLED
  @@map("workflow_status_enum")
  @@schema("factory")
}

enum StepActionEnum {
  SUBMITTED
  APPROVED
  REJECTED
  ESCALATED
  RECALLED
  REASSIGNED
  @@map("step_action_enum")
  @@schema("factory")
}

enum SupplementaryReasonEnum {
  NEGLIGENCE
  GENUINE_SHORTAGE
  @@map("supplementary_reason_enum")
  @@schema("factory")
}

enum SupplementaryStatusEnum {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  TRANSFERRED
  CANCELLED
  @@map("supplementary_status_enum")
  @@schema("factory")
}

enum CmoPriorityEnum {
  LOW
  NORMAL
  HIGH
  URGENT
  @@map("cmo_priority_enum")
  @@schema("factory")
}

enum CmoStatusEnum {
  DRAFT
  CONFIRMED
  IN_PROGRESS
  PARTIALLY_DELIVERED
  FULFILLED
  CLOSED
  CANCELLED
  @@map("cmo_status_enum")
  @@schema("factory")
}

enum CmoLineStatusEnum {
  PENDING
  RELEASED
  IN_PRODUCTION
  PRODUCED
  PACKED
  PARTIALLY_DELIVERED
  FULLY_DELIVERED
  CANCELLED
  @@map("cmo_line_status_enum")
  @@schema("factory")
}

enum ShippingOrderStatusEnum {
  DRAFT
  LOADING
  LOADED
  DISPATCHED
  DELIVERED
  CANCELLED
  @@map("shipping_order_status_enum")
  @@schema("factory")
}

enum RootCauseCategoryEnum {
  ACTUAL_CONTAINER_SHORTAGE
  PRODUCTION_LINE_NEGLIGENCE
  EXCESSIVE_SCRAP
  COUNTING_ERROR
  QUALITY_REPLACEMENT
  PACKAGING_LIST_VARIANCE
  OTHER
  @@map("root_cause_category_enum")
  @@schema("factory")
}

enum AccountabilityClosureEnum {
  OPEN
  IN_REVIEW
  CLOSED
  @@map("accountability_closure_enum")
  @@schema("factory")
}

enum InvestigationTypeEnum {
  INVENTORY_VARIANCE
  PHYSICAL_COUNT_DISCREPANCY
  MISSING_BAG
  MISSING_PART
  CONTAINER_SHORTAGE
  SUPPLEMENTARY_MATERIAL_ABUSE
  OTHER
  @@map("investigation_type_enum")
  @@schema("factory")
}

enum PermissionTypeEnum {
  VIEW
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  CANCEL
  PRINT
  EXPORT
  @@map("permission_type_enum")
  @@schema("factory")
}

enum UserStatusEnum {
  ACTIVE
  INACTIVE
  LOCKED
  PENDING_ACTIVATION
  @@map("user_status_enum")
  @@schema("factory")
}

model customers {
  customer_id BigInt @id @default(autoincrement())
  customer_code String @db.VarChar(20) @unique
  customer_name String @db.VarChar(200)
  is_active Boolean @default(true)
  created_at DateTime @db.Timestamptz(6) @default(now())
  updated_at DateTime @db.Timestamptz(6) @default(now())
  models models[] @relation("models__customer_id__customers")
  physical_bags physical_bags[] @relation("physical_bags__customer_id__customers")
  finished_goods_bags finished_goods_bags[] @relation("finished_goods_bags__customer_id__customers")
  customer_manufacturing_orders customer_manufacturing_orders[] @relation("customer_manufacturing_orders__customer_id__customers")
  shipping_orders shipping_orders[] @relation("shipping_orders__customer_id__customers")
  @@schema("factory")
}

model suppliers {
  supplier_id BigInt @id @default(autoincrement())
  supplier_code String @db.VarChar(20) @unique
  supplier_name String @db.VarChar(200)
  contact_info Json? @db.JsonB
  is_active Boolean @default(true)
  created_at DateTime @db.Timestamptz(6) @default(now())
  updated_at DateTime @db.Timestamptz(6) @default(now())
  containers containers[] @relation("containers__supplier_id__suppliers")
  @@schema("factory")
}

model colors {
  color_id BigInt @id @default(autoincrement())
  color_code String @db.VarChar(20) @unique
  color_name String @db.VarChar(100)
  hex_value String? @db.Char(7)
  model_colors model_colors[] @relation("model_colors__color_id__colors")
  packing_pattern_lines packing_pattern_lines[] @relation("packing_pattern_lines__color_id__colors")
  packaging_list_items packaging_list_items[] @relation("packaging_list_items__color_id__colors")
  receiving_audit_items receiving_audit_items[] @relation("receiving_audit_items__color_id__colors")
  scrap_records scrap_records[] @relation("scrap_records__color_id__colors")
  inventory_transactions inventory_transactions[] @relation("inventory_transactions__color_id__colors")
  physical_bag_contents physical_bag_contents[] @relation("physical_bag_contents__color_id__colors")
  physical_bag_content_adjustments physical_bag_content_adjustments[] @relation("physical_bag_content_adjustments__color_id__colors")
  quality_output_boxes quality_output_boxes[] @relation("quality_output_boxes__color_id__colors")
  dozen_assembly_lines dozen_assembly_lines[] @relation("dozen_assembly_lines__color_id__colors")
  customer_manufacturing_order_lines customer_manufacturing_order_lines[] @relation("customer_manufacturing_order_lines__color_id__colors")
  @@schema("factory")
}

model sizes {
  size_id BigInt @id @default(autoincrement())
  size_code String @db.VarChar(10) @unique
  sort_order Int
  model_sizes model_sizes[] @relation("model_sizes__size_id__sizes")
  packing_pattern_lines packing_pattern_lines[] @relation("packing_pattern_lines__size_id__sizes")
  packaging_list_items packaging_list_items[] @relation("packaging_list_items__size_id__sizes")
  receiving_audit_items receiving_audit_items[] @relation("receiving_audit_items__size_id__sizes")
  scrap_records scrap_records[] @relation("scrap_records__size_id__sizes")
  inventory_transactions inventory_transactions[] @relation("inventory_transactions__size_id__sizes")
  physical_bag_contents physical_bag_contents[] @relation("physical_bag_contents__size_id__sizes")
  physical_bag_content_adjustments physical_bag_content_adjustments[] @relation("physical_bag_content_adjustments__size_id__sizes")
  quality_output_boxes quality_output_boxes[] @relation("quality_output_boxes__size_id__sizes")
  dozen_assembly_lines dozen_assembly_lines[] @relation("dozen_assembly_lines__size_id__sizes")
  customer_manufacturing_order_lines customer_manufacturing_order_lines[] @relation("customer_manufacturing_order_lines__size_id__sizes")
  @@schema("factory")
}

model production_lines {
  line_id BigInt @id @default(autoincrement())
  line_code String @db.VarChar(10) @unique
  line_name String @db.VarChar(100)
  is_active Boolean @default(true)
  production_orders production_orders[] @relation("production_orders__line_id__production_lines")
  production_stage_logs production_stage_logs[] @relation("production_stage_logs__line_id__production_lines")
  wip_inventory wip_inventory[] @relation("wip_inventory__line_id__production_lines")
  employees employees[] @relation("employees__primary_line_id__production_lines")
  employee_stage_assignments employee_stage_assignments[] @relation("employee_stage_assignments__line_id__production_lines")
  line_kpi_summary line_kpi_summary[] @relation("line_kpi_summary__line_id__production_lines")
  machines machines[] @relation("machines__assigned_line_id__production_lines")
  machine_assignments machine_assignments[] @relation("machine_assignments__line_id__production_lines")
  machine_oee_snapshots machine_oee_snapshots[] @relation("machine_oee_snapshots__line_id__production_lines")
  @@schema("factory")
}

model warehouses {
  warehouse_id BigInt @id @default(autoincrement())
  warehouse_code String @db.VarChar(20) @unique
  warehouse_name String @db.VarChar(200)
  warehouse_type WarehouseTypeEnum
  is_active Boolean @default(true)
  release_group_lines release_group_lines[] @relation("release_group_lines__source_warehouse_id__warehouses")
  return_transactions return_transactions[] @relation("return_transactions__destination_warehouse_id__warehouses")
  inventory_bags inventory_bags[] @relation("inventory_bags__warehouse_id__warehouses")
  physical_bags physical_bags[] @relation("physical_bags__current_warehouse_id__warehouses")
  physical_bag_movements physical_bag_movements[] @relation("physical_bag_movements__from_warehouse_id__warehouses")
  physical_bag_movements_to_warehouse_id physical_bag_movements[] @relation("physical_bag_movements__to_warehouse_id__warehouses")
  finished_goods_bags finished_goods_bags[] @relation("finished_goods_bags__warehouse_id__warehouses")
  supplementary_request_lines supplementary_request_lines[] @relation("supplementary_request_lines__source_warehouse_id__warehouses")
  inventory_investigations inventory_investigations[] @relation("inventory_investigations__warehouse_id__warehouses")
  @@schema("factory")
}

model production_stages {
  stage_id BigInt @id @default(autoincrement())
  stage_code String @db.VarChar(30) @unique
  stage_name String @db.VarChar(100)
  sequence_order Int @unique
  production_stage_logs production_stage_logs[] @relation("production_stage_logs__stage_id__production_stages")
  scrap_records scrap_records[] @relation("scrap_records__stage_id__production_stages")
  incomplete_item_records incomplete_item_records[] @relation("incomplete_item_records__stage_id__production_stages")
  employees employees[] @relation("employees__primary_stage_id__production_stages")
  employee_stage_assignments employee_stage_assignments[] @relation("employee_stage_assignments__stage_id__production_stages")
  employee_daily_output employee_daily_output[] @relation("employee_daily_output__stage_id__production_stages")
  stage_standard_minutes stage_standard_minutes[] @relation("stage_standard_minutes__stage_id__production_stages")
  employee_kpi_daily employee_kpi_daily[] @relation("employee_kpi_daily__stage_id__production_stages")
  machines machines[] @relation("machines__assigned_stage_id__production_stages")
  machine_assignments machine_assignments[] @relation("machine_assignments__stage_id__production_stages")
  supplementary_request_negligence supplementary_request_negligence[] @relation("supplementary_request_negligence__stage_id__production_stages")
  @@schema("factory")
}

model departments {
  department_id BigInt @id @default(autoincrement())
  dept_code String @db.VarChar(20) @unique
  dept_name String @db.VarChar(100)
  is_active Boolean @default(true)
  employees employees[] @relation("employees__department_id__departments")
  inventory_investigations inventory_investigations[] @relation("inventory_investigations__responsible_department_id__departments")
  users users[] @relation("users__department_id__departments")
  roles roles[] @relation("roles__department_id__departments")
  @@schema("factory")
}

model models {
  model_id BigInt @id @default(autoincrement())
  customer_id BigInt
  model_code String @db.VarChar(50)
  model_name String? @db.VarChar(200)
  is_active Boolean @default(true)
  created_at DateTime @db.Timestamptz(6) @default(now())
  updated_at DateTime @db.Timestamptz(6) @default(now())
  customers customers @relation("models__customer_id__customers", fields: [customer_id], references: [customer_id])
  model_parts model_parts[] @relation("model_parts__model_id__models")
  model_colors model_colors[] @relation("model_colors__model_id__models")
  model_sizes model_sizes[] @relation("model_sizes__model_id__models")
  packing_patterns packing_patterns[] @relation("packing_patterns__model_id__models")
  packaging_list_items packaging_list_items[] @relation("packaging_list_items__model_id__models")
  receiving_audit_items receiving_audit_items[] @relation("receiving_audit_items__model_id__models")
  production_orders production_orders[] @relation("production_orders__model_id__models")
  inventory_bags inventory_bags[] @relation("inventory_bags__model_id__models")
  inventory_transactions inventory_transactions[] @relation("inventory_transactions__model_id__models")
  physical_bags physical_bags[] @relation("physical_bags__model_id__models")
  quality_output_boxes quality_output_boxes[] @relation("quality_output_boxes__model_id__models")
  finished_goods_bags finished_goods_bags[] @relation("finished_goods_bags__model_id__models")
  stage_standard_minutes stage_standard_minutes[] @relation("stage_standard_minutes__model_id__models")
  customer_manufacturing_order_lines customer_manufacturing_order_lines[] @relation("customer_manufacturing_order_lines__model_id__models")
  inventory_investigations inventory_investigations[] @relation("inventory_investigations__model_id__models")
  @@unique([customer_id, model_code])
  @@index([customer_id])
  // GIN index (managed in SQL, not PSL): idx_models_code_trgm (model_code)
  @@schema("factory")
}

model model_parts {
  part_id BigInt @id @default(autoincrement())
  model_id BigInt
  part_code String @db.VarChar(10)
  part_description String? @db.VarChar(200)
  sort_order Int @default(0)
  models models @relation("model_parts__model_id__models", fields: [model_id], references: [model_id])
  packaging_list_items packaging_list_items[] @relation("packaging_list_items__part_id__model_parts")
  receiving_audit_items receiving_audit_items[] @relation("receiving_audit_items__part_id__model_parts")
  production_order_parts production_order_parts[] @relation("production_order_parts__part_id__model_parts")
  return_transactions return_transactions[] @relation("return_transactions__part_id__model_parts")
  inventory_bags inventory_bags[] @relation("inventory_bags__part_id__model_parts")
  wip_inventory wip_inventory[] @relation("wip_inventory__part_id__model_parts")
  inventory_transactions inventory_transactions[] @relation("inventory_transactions__part_id__model_parts")
  physical_bags physical_bags[] @relation("physical_bags__part_id__model_parts")
  supplementary_request_lines supplementary_request_lines[] @relation("supplementary_request_lines__part_id__model_parts")
  inventory_investigations inventory_investigations[] @relation("inventory_investigations__part_id__model_parts")
  @@unique([model_id, part_code])
  @@index([model_id])
  @@schema("factory")
}

model model_colors {
  model_color_id BigInt @id @default(autoincrement())
  model_id BigInt
  color_id BigInt
  models models @relation("model_colors__model_id__models", fields: [model_id], references: [model_id])
  colors colors @relation("model_colors__color_id__colors", fields: [color_id], references: [color_id])
  @@unique([model_id, color_id])
  @@index([model_id])
  @@schema("factory")
}

model model_sizes {
  model_size_id BigInt @id @default(autoincrement())
  model_id BigInt
  size_id BigInt
  models models @relation("model_sizes__model_id__models", fields: [model_id], references: [model_id])
  sizes sizes @relation("model_sizes__size_id__sizes", fields: [size_id], references: [size_id])
  @@unique([model_id, size_id])
  @@index([model_id])
  @@schema("factory")
}

model roles {
  role_id BigInt @id @default(autoincrement())
  role_code String @db.VarChar(30) @unique
  role_name String @db.VarChar(100)
  description String?
  parent_role_id BigInt?
  role_group String? @db.VarChar(50)
  department_id BigInt?
  is_system_role Boolean @default(false)
  hierarchy_level Int @default(0)
  roles_parent roles? @relation("roles__parent_role_id__roles", fields: [parent_role_id], references: [role_id])
  departments departments? @relation("roles__department_id__departments", fields: [department_id], references: [department_id])
  users users[] @relation("users__role_id__roles")
  role_permissions role_permissions[] @relation("role_permissions__role_id__roles")
  workflow_template_steps workflow_template_steps[] @relation("workflow_template_steps__required_role_id__roles")
  workflow_template_steps_escalation_role_id workflow_template_steps[] @relation("workflow_template_steps__escalation_role_id__roles")
  roles_children roles[] @relation("roles__parent_role_id__roles")
  screen_permissions screen_permissions[] @relation("screen_permissions__role_id__roles")
  approval_permissions approval_permissions[] @relation("approval_permissions__role_id__roles")
  session_policy session_policy[] @relation("session_policy__role_id__roles")
  @@schema("factory")
}

model users {
  user_id BigInt @id @default(autoincrement())
  username String @db.VarChar(50) @unique
  full_name String @db.VarChar(200)
  email String? @db.VarChar(200) @unique
  password_hash String @db.VarChar(500)
  role_id BigInt
  is_active Boolean @default(true)
  created_at DateTime @db.Timestamptz(6) @default(now())
  last_login_at DateTime? @db.Timestamptz(6)
  department_id BigInt?
  status UserStatusEnum @default(ACTIVE)
  must_change_password Boolean @default(false)
  failed_login_count Int @default(0)
  locked_at DateTime? @db.Timestamptz(6)
  locked_reason String? @db.VarChar(200)
  updated_by BigInt?
  updated_at DateTime? @db.Timestamptz(6)
  roles roles @relation("users__role_id__roles", fields: [role_id], references: [role_id])
  departments departments? @relation("users__department_id__departments", fields: [department_id], references: [department_id])
  users_parent users? @relation("users__updated_by__users", fields: [updated_by], references: [user_id])
  audit_events audit_events[] @relation("audit_events__user_id__users")
  packing_patterns packing_patterns[] @relation("packing_patterns__created_by__users")
  containers containers[] @relation("containers__created_by__users")
  containers_approved_by containers[] @relation("containers__approved_by__users")
  receiving_audit_items receiving_audit_items[] @relation("receiving_audit_items__audited_by__users")
  production_orders production_orders[] @relation("production_orders__created_by__users")
  production_orders_closed_by production_orders[] @relation("production_orders__closed_by__users")
  production_order_parts production_order_parts[] @relation("production_order_parts__released_by__users")
  release_groups release_groups[] @relation("release_groups__released_by__users")
  production_stage_logs production_stage_logs[] @relation("production_stage_logs__started_by__users")
  production_stage_logs_completed_by production_stage_logs[] @relation("production_stage_logs__completed_by__users")
  scrap_records scrap_records[] @relation("scrap_records__recorded_by__users")
  incomplete_item_records incomplete_item_records[] @relation("incomplete_item_records__recorded_by__users")
  return_transactions return_transactions[] @relation("return_transactions__returned_by__users")
  inventory_transactions inventory_transactions[] @relation("inventory_transactions__executed_by__users")
  physical_bags physical_bags[] @relation("physical_bags__created_by__users")
  physical_bag_movements physical_bag_movements[] @relation("physical_bag_movements__performed_by__users")
  physical_bag_reservations physical_bag_reservations[] @relation("physical_bag_reservations__reserved_by__users")
  physical_bag_content_adjustments physical_bag_content_adjustments[] @relation("physical_bag_content_adjustments__adjusted_by__users")
  packing_orders packing_orders[] @relation("packing_orders__created_by__users")
  packing_orders_started_by packing_orders[] @relation("packing_orders__started_by__users")
  packing_orders_verified_by packing_orders[] @relation("packing_orders__verified_by__users")
  packing_orders_posted_by packing_orders[] @relation("packing_orders__posted_by__users")
  dozen_assemblies dozen_assemblies[] @relation("dozen_assemblies__assembled_by__users")
  packing_verifications packing_verifications[] @relation("packing_verifications__verified_by__users")
  employees employees[] @relation("employees__user_id__users")
  employee_attendance employee_attendance[] @relation("employee_attendance__recorded_by__users")
  employee_stage_assignments employee_stage_assignments[] @relation("employee_stage_assignments__assigned_by__users")
  employee_daily_output employee_daily_output[] @relation("employee_daily_output__recorded_by__users")
  stage_standard_minutes stage_standard_minutes[] @relation("stage_standard_minutes__set_by__users")
  machines machines[] @relation("machines__created_by__users")
  machine_assignments machine_assignments[] @relation("machine_assignments__assigned_by__users")
  machine_status_log machine_status_log[] @relation("machine_status_log__changed_by__users")
  machine_maintenance_schedule machine_maintenance_schedule[] @relation("machine_maintenance_schedule__created_by__users")
  machine_downtime_events machine_downtime_events[] @relation("machine_downtime_events__reported_by__users")
  machine_downtime_events_resolved_by machine_downtime_events[] @relation("machine_downtime_events__resolved_by__users")
  workflow_instances workflow_instances[] @relation("workflow_instances__submitted_by__users")
  workflow_step_actions workflow_step_actions[] @relation("workflow_step_actions__action_by__users")
  supplementary_material_requests supplementary_material_requests[] @relation("supplementary_material_requests__requested_by__users")
  supplementary_material_requests_transferred_by supplementary_material_requests[] @relation("supplementary_material_requests__transferred_by__users")
  supplementary_request_negligence supplementary_request_negligence[] @relation("supplementary_request_negligence__reported_by__users")
